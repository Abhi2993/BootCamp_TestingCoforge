package com.SeleniumWebDriver.LocatorsDemo;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.annotations.Test;

public class class_Locator {

    @Test
    public void TestDemo() throws Exception {

        WebDriver driver = new ChromeDriver();

        driver.manage().window().maximize();

        driver.navigate().to("https://www.hollandandbarrett.com/shop/vitamins-supplements/vitamins/");

        Thread.sleep(10000);

        try {
            driver.findElement(By.id("/html/body/div[6]/div[2]/div/div/div[2]/div/div/button[1]")).click();
        } catch (Exception e) {
            System.out.println("Cookie popup not displayed.");
        }

        driver.findElement(By.xpath("//a[@aria-label='Link to Vitamin Drinks category']//div[@class='NavCategoryItem-module_categoryImageWrapper__Y0yy6']")).click();
        driver.findElement(By.className("ProductCardImage-module_innerImage__2kx-2P")).click();
        String BrowserTitle = driver.getCurrentUrl();
        System.out.println(BrowserTitle);

        driver.navigate().back();
        BrowserTitle = driver.getCurrentUrl();
        System.out.println(BrowserTitle);

        driver.navigate().refresh();
        BrowserTitle = driver.getCurrentUrl();
        System.out.println(BrowserTitle);

        driver.quit();
    }
}